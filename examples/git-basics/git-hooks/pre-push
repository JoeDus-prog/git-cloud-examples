#!/usr/bin/env bash

# =============================================================================
# Git Pre-Push Hook
# 
# Dieser Hook wird VOR jedem Push ausgefuehrt.
# Er verhindert Pushes, wenn:
#   - Es ungetestete Aenderungen gibt
#   - Die Branch nicht mit remote synchronisiert ist
#   - Es Konflikte gibt
# 
# Installation:
#   1. Kopiere diese Datei nach .git/hooks/pre-push
#   2. Mache sie ausfuehrbar: chmod +x .git/hooks/pre-push
# =============================================================================

# Farben fuer die Ausgabe
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Fehlerzaehler
ERRORS=0

print_error() {
    printf "%s\n" "${RED}✗ $1${NC}"
    ERRORS=$((ERRORS + 1))
}

print_warning() {
    printf "%s\n" "${YELLOW}⚠ $1${NC}"
}

print_success() {
    printf "%s\n" "${GREEN}✓ $1${NC}"
}

printf "\nRunning pre-push checks...\n\n"

# =============================================================================
# 1. Aktuellen Branch ermitteln
# =============================================================================

CURRENT_BRANCH=$(git branch --show-current)
REMOTE_BRANCH="origin/$CURRENT_BRANCH"

printf "Current branch: %s\n" "$CURRENT_BRANCH"
printf "Remote branch: %s\n\n" "$REMOTE_BRANCH"

# =============================================================================
# 2. Ueberpruefen ob Branch mit Remote synchronisiert ist
# =============================================================================

printf "Checking if branch is up to date with remote...\n"

# Ueberpruefen ob Remote-Branch existiert
if ! git ls-remote --exit-code --heads origin "$CURRENT_BRANCH" > /dev/null 2>&1; then
    # Branch existiert noch nicht auf Remote - das ist OK fuer neue Branches
    print_success "New branch - no remote to compare with"
else
    # Ueberpruefen ob lokale Aenderungen mit Remote synchronisiert sind
    if [ "$(git rev-parse @)" != "$(git rev-parse @{u})" ]; then
        print_error "Branch is not up to date with remote"
        printf "\nPlease run:\n"
        printf "  git pull --rebase\n\n"
    else
        print_success "Branch is up to date with remote"
    fi
fi

# =============================================================================
# 3. Ueberpruefen auf ungetestete Aenderungen
# =============================================================================

printf "\nChecking for uncommitted changes...\n"

# Ueberpruefen auf unstaged Aenderungen
if ! git diff --quiet; then
    print_error "Unstaged changes detected"
    printf "\nPlease stage or commit your changes:\n"
    git status --short
    printf "\n"
fi

# Ueberpruefen auf uncommitted (staged) Aenderungen
if ! git diff --cached --quiet; then
    print_error "Uncommitted staged changes detected"
    printf "\nPlease commit your changes:\n"
    git status --short
    printf "\n"
fi

# =============================================================================
# 4. Ueberpruefen auf Merge-Konflikte
# =============================================================================

printf "\nChecking for merge conflicts...\n"

if git ls-files --unmerged | grep -q .; then
    print_error "Merge conflicts detected"
    printf "\nPlease resolve conflicts first:\n"
    git status --short
    printf "\n"
fi

# =============================================================================
# 5. Tests ausfuehren (falls verfuegbar)
# =============================================================================

if [ -f "package.json" ] && command -v npm > /dev/null 2>&1; then
    printf "\nRunning tests...\n"
    if ! npm test > /dev/null 2>&1; then
        print_error "Tests failed. Push aborted."
        printf "\nRun 'npm test' to see errors.\n"
    else
        print_success "Tests passed"
    fi
fi

# =============================================================================
# 6. Branch-Schutz ueberpruefen
# =============================================================================

printf "\nChecking branch protection rules...\n"

# Schutz fuer main/master Branches
if [ "$CURRENT_BRANCH" = "main" ] || [ "$CURRENT_BRANCH" = "master" ]; then
    print_error "Direct push to $CURRENT_BRANCH is not allowed"
    printf "\nPlease use a feature branch and create a Pull Request.\n"
fi

# =============================================================================
# 7. Commit-Historie ueberpruefen
# =============================================================================

printf "\nChecking commit history...\n"

# Ueberpruefen auf zu viele Commits auf einmal
COMMIT_COUNT=$(git rev-list --count HEAD@{1}..HEAD 2>/dev/null || echo "0")

if [ "$COMMIT_COUNT" -gt 20 ]; then
    print_warning "Pushing $COMMIT_COUNT commits at once"
    print_warning "Consider splitting into smaller, focused commits"
fi

# =============================================================================
# Ergebnis
# =============================================================================

printf "\n"

if [ "$ERRORS" -gt 0 ]; then
    printf "%s\n" "${RED}Pre-push checks failed with $ERRORS error(s)${NC}"
    printf "\nFix the errors and try pushing again.\n"
    exit 1
else
    printf "%s\n" "${GREEN}All pre-push checks passed!${NC}"
    printf "\nPushing to %s...\n" "$REMOTE_BRANCH"
    exit 0
fi
