#!/bin/sh

# =============================================================================
# Git Pre-Commit Hook
# 
# Dieser Hook wird VOR jedem Commit ausgeführt.
# Er verhindert Commits, wenn:
#   - Es Linting-Fehler gibt
#   - Tests fehlschlagen
#   - Es ungewollte Dateien im Commit gibt
# 
# Installation:
#   1. Kopiere diese Datei nach .git/hooks/pre-commit
#   2. Mache sie ausführbar: chmod +x .git/hooks/pre-commit
# =============================================================================

# Farben für die Ausgabe
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Fehlerzähler
ERRORS=0

# Funktion zum Ausgeben von Fehlern
print_error() {
    echo -e "${RED}✗ $1${NC}"
    ERRORS=$((ERRORS + 1))
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

echo ""
echo "Running pre-commit checks..."
echo ""

# =============================================================================
# 1. Überprüfen auf große Dateien (> 10MB)
# =============================================================================

echo "Checking for large files..."
LARGE_FILES=$(git diff --cached --name-only | xargs find -type f -size +10M 2>/dev/null)

if [ -n "$LARGE_FILES" ]; then
    print_error "Large files detected (> 10MB):"
    echo "$LARGE_FILES"
    echo ""
    echo "Please use git lfs for large files or remove them from the commit."
    echo ""
fi

# =============================================================================
# 2. Überprüfen auf Secrets (API Keys, Passwords, etc.)
# =============================================================================

echo "Checking for potential secrets..."

# Muster für Secrets
SECRET_PATTERNS=(
    "API_KEY"
    "API_SECRET"
    "ACCESS_TOKEN"
    "SECRET_KEY"
    "PASSWORD"
    "PRIVATE_KEY"
    "AWS_ACCESS_KEY_ID"
    "AWS_SECRET_ACCESS_KEY"
    "GITHUB_TOKEN"
    "Heroku API Key"
    "aws_access_key_id"
    "aws_secret_access_key"
)

# Dateien im Staging-Bereich überprüfen
STAGED_FILES=$(git diff --cached --name-only)

for FILE in $STAGED_FILES; do
    # Nur Textdateien überprüfen
    if file "$FILE" | grep -q "text"; then
        for PATTERN in "${SECRET_PATTERNS[@]}"; do
            if grep -i -q "$PATTERN" "$FILE" 2>/dev/null; then
                print_error "Potential secret found in $FILE: $PATTERN"
            fi
        done
    fi
done

# =============================================================================
# 3. Überprüfen auf Trailing Whitespace
# =============================================================================

echo "Checking for trailing whitespace..."
TRAILING_WHITESPACE=$(git diff --cached --check | grep -c "^+" || true)

if [ "$TRAILING_WHITESPACE" -gt 0 ]; then
    print_error "Trailing whitespace found in $(git diff --cached --check | grep "^+" | wc -l) line(s)"
    echo "Run 'git diff --cached --check' to see the lines."
fi

# =============================================================================
# 4. Linting (falls verfügbar)
# =============================================================================

if [ -f "package.json" ] && command -v npm > /dev/null 2>&1; then
    echo "Running npm lint..."
    if ! npm run lint > /dev/null 2>&1; then
        print_error "Linting failed. Run 'npm run lint' to see errors."
    else
        print_success "Linting passed"
    fi
fi

if [ -f "requirements.txt" ] && command -v flake8 > /dev/null 2>&1; then
    echo "Running flake8..."
    STAGED_PYTHON_FILES=$(git diff --cached --name-only | grep '\.py$')
    if [ -n "$STAGED_PYTHON_FILES" ]; then
        if ! flake8 $STAGED_PYTHON_FILES; then
            print_error "flake8 found issues"
        else
            print_success "flake8 passed"
        fi
    fi
fi

# =============================================================================
# 5. Tests (falls verfügbar)
# =============================================================================

if [ -f "package.json" ] && command -v npm > /dev/null 2>&1; then
    echo "Running tests..."
    if ! npm test > /dev/null 2>&1; then
        print_error "Tests failed. Run 'npm test' to see errors."
    else
        print_success "Tests passed"
    fi
fi

# =============================================================================
# 6. Commit-Nachricht überprüfen
# =============================================================================

echo "Checking commit message..."
COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Überprüfen auf leere Commit-Nachricht
if [ -z "$COMMIT_MSG" ]; then
    print_error "Empty commit message"
fi

# Überprüfen auf zu kurze Commit-Nachricht (mind. 10 Zeichen)
if [ ${#COMMIT_MSG} -lt 10 ]; then
    print_error "Commit message too short (minimum 10 characters)"
fi

# Überprüfen auf Conventional Commits Format
if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|style|refactor|test|chore)(\([^)]*\))?: .+$'; then
    print_warning "Commit message does not follow Conventional Commits format"
    print_warning "Recommended format: type(scope): description"
    print_warning "Types: feat, fix, docs, style, refactor, test, chore"
fi

# =============================================================================
# Ergebnis
# =============================================================================

echo ""

if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}Pre-commit checks failed with $ERRORS error(s)${NC}"
    echo ""
    echo "Fix the errors and try committing again."
    exit 1
else
    echo -e "${GREEN}All pre-commit checks passed!${NC}"
    exit 0
fi
