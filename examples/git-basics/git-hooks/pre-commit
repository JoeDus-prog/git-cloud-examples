#!/usr/bin/env bash

# =============================================================================
# Git Pre-Commit Hook
# 
# Dieser Hook wird VOR jedem Commit ausgefuehrt.
# Er verhindert Commits, wenn:
#   - Es Linting-Fehler gibt
#   - Tests fehlschlagen
#   - Es ungewollte Dateien im Commit gibt
# 
# Installation:
#   1. Kopiere diese Datei nach .git/hooks/pre-commit
#   2. Mache sie ausfuehrbar: chmod +x .git/hooks/pre-commit
# =============================================================================

# Farben fuer die Ausgabe
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Fehlerzaehler
ERRORS=0

# Funktion zum Ausgeben von Fehlern
print_error() {
    printf "%s\n" "${RED}✗ $1${NC}"
    ERRORS=$((ERRORS + 1))
}

print_warning() {
    printf "%s\n" "${YELLOW}⚠ $1${NC}"
}

print_success() {
    printf "%s\n" "${GREEN}✓ $1${NC}"
}

printf "\nRunning pre-commit checks...\n\n"

# =============================================================================
# 1. Ueberpruefen auf grosse Dateien (> 10MB)
# =============================================================================

printf "Checking for large files...\n"
LARGE_FILES=$(git diff --cached --name-only | xargs find -type f -size +10M 2>/dev/null)

if [ -n "$LARGE_FILES" ]; then
    print_error "Large files detected (> 10MB):"
    printf "%s\n" "$LARGE_FILES"
    printf "\nPlease use git lfs for large files or remove them from the commit.\n\n"
fi

# =============================================================================
# 2. Ueberpruefen auf Secrets (API Keys, Passwords, etc.)
# =============================================================================

printf "Checking for potential secrets...\n"

# Muster fuer Secrets
SECRET_PATTERNS=(
    "API_KEY"
    "API_SECRET"
    "ACCESS_TOKEN"
    "SECRET_KEY"
    "PASSWORD"
    "PRIVATE_KEY"
    "AWS_ACCESS_KEY_ID"
    "AWS_SECRET_ACCESS_KEY"
    "GITHUB_TOKEN"
    "Heroku API Key"
    "aws_access_key_id"
    "aws_secret_access_key"
)

# Dateien im Staging-Bereich ueberpruefen
STAGED_FILES=$(git diff --cached --name-only)

for FILE in $STAGED_FILES; do
    # Nur Textdateien ueberpruefen
    if file "$FILE" | grep -q "text"; then
        for PATTERN in "${SECRET_PATTERNS[@]}"; do
            if grep -i -q "$PATTERN" "$FILE" 2>/dev/null; then
                print_error "Potential secret found in $FILE: $PATTERN"
            fi
        done
    fi
done

# =============================================================================
# 3. Ueberpruefen auf Trailing Whitespace
# =============================================================================

printf "Checking for trailing whitespace...\n"
TRAILING_WHITESPACE=$(git diff --cached --check | grep -c "^+" || true)

if [ "$TRAILING_WHITESPACE" -gt 0 ]; then
    LINE_COUNT=$(git diff --cached --check | grep "^+" | wc -l)
    print_error "Trailing whitespace found in ${LINE_COUNT} line(s)"
    printf "Run 'git diff --cached --check' to see the lines.\n"
fi

# =============================================================================
# 4. Linting (falls verfuegbar)
# =============================================================================

if [ -f "package.json" ] && command -v npm > /dev/null 2>&1; then
    printf "Running npm lint...\n"
    if ! npm run lint > /dev/null 2>&1; then
        print_error "Linting failed. Run 'npm run lint' to see errors."
    else
        print_success "Linting passed"
    fi
fi

if [ -f "requirements.txt" ] && command -v flake8 > /dev/null 2>&1; then
    printf "Running flake8...\n"
    STAGED_PYTHON_FILES=$(git diff --cached --name-only | grep '\.py$')
    if [ -n "$STAGED_PYTHON_FILES" ]; then
        if ! flake8 $STAGED_PYTHON_FILES; then
            print_error "flake8 found issues"
        else
            print_success "flake8 passed"
        fi
    fi
fi

# =============================================================================
# 5. Tests (falls verfuegbar)
# =============================================================================

if [ -f "package.json" ] && command -v npm > /dev/null 2>&1; then
    printf "Running tests...\n"
    if ! npm test > /dev/null 2>&1; then
        print_error "Tests failed. Run 'npm test' to see errors."
    else
        print_success "Tests passed"
    fi
fi

# =============================================================================
# 6. Commit-Nachricht ueberpruefen
# =============================================================================

printf "Checking commit message...\n"
COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Ueberpruefen auf leere Commit-Nachricht
if [ -z "$COMMIT_MSG" ]; then
    print_error "Empty commit message"
fi

# Ueberpruefen auf zu kurze Commit-Nachricht (mind. 10 Zeichen)
if [ "${#COMMIT_MSG}" -lt 10 ]; then
    print_error "Commit message too short (minimum 10 characters)"
fi

# Ueberpruefen auf Conventional Commits Format
if ! printf "%s" "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|style|refactor|test|chore)(\([^)]*\))?: .+$'; then
    print_warning "Commit message does not follow Conventional Commits format"
    print_warning "Recommended format: type(scope): description"
    print_warning "Types: feat, fix, docs, style, refactor, test, chore"
fi

# =============================================================================
# Ergebnis
# =============================================================================

printf "\n"

if [ "$ERRORS" -gt 0 ]; then
    printf "%s\n" "${RED}Pre-commit checks failed with $ERRORS error(s)${NC}"
    printf "\nFix the errors and try committing again.\n"
    exit 1
else
    printf "%s\n" "${GREEN}All pre-commit checks passed!${NC}"
    exit 0
fi
